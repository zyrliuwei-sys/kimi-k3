{
  "name": "shipany-tanstack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "prebuild": "node scripts/db-setup.mjs",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "precf:build": "node scripts/db-setup.mjs",
    "cf:build": "NITRO_PRESET=cloudflare_module vite build",
    "cf:deploy": "sh -c 'set -a && [ -f .env.production ] && . ./.env.production; set +a && pnpm cf:build && exec wrangler deploy'",
    "postinstall": "mkdir -p data && (test -f src/config/db/schema.ts || node scripts/db-setup.mjs)",
    "db:setup": "node scripts/db-setup.mjs",
    "db:push": "tsx scripts/with-env.ts drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "tsx scripts/with-env.ts drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/with-env.ts drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "tsx scripts/with-env.ts drizzle-kit studio --config=drizzle.config.ts",
    "rbac:init": "tsx scripts/with-env.ts tsx scripts/init-rbac.ts",
    "rbac:assign": "tsx scripts/with-env.ts tsx scripts/assign-role.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "prettier --write",
    "*.{json,css,md,mdx,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/libre-baskerville": "^5.2.10",
    "@libsql/client": "^0.14.0",
    "@mdx-js/react": "^3.1.1",
    "@react-email/components": "^1.0.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-start": "^1.168.19",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@types/mdx": "^2.0.13",
    "aws4fetch": "^1.0.0",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^0.511.0",
    "markdown-it": "^14.2.0",
    "motion": "^12.38.0",
    "mysql2": "^3.14.0",
    "nanoid": "^5.0.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "3.8.0",
    "replicate": "^1.0.0",
    "resend": "^4.0.0",
    "shadcn": "^4.2.0",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.1",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@inlang/paraglide-js": "^2.18.2",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp"
    ]
  }
}
